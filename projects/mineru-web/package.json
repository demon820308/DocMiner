{
  "name": "docminer",
  "version": "1.0.13",
  "description": "DocMiner Desktop Client",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/demon820308/DocMiner.git"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "docminer",
    "pdf",
    "parser",
    "desktop"
  ],
  "author": "DocMiner Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.demon.docminer",
    "productName": "DocMiner",
    "asar": false,
    "icon": "assets/logo.png",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../../mineru",
        "to": "mineru",
        "filter": [
          "**/*",
          "!**/*.pyc",
          "!**/__pycache__"
        ]
      },
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*",
          "!**/*.pyc",
          "!**/__pycache__",
          "!temp_download/**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DocMiner"
    },
    "mac": {
      "target": "dmg"
    },
    "directories": {
      "output": "dist"
    }
  }
}
